#!/usr/bin/env bash
# Лаунчер ZubriTunnel.app
# Source-файлы внутри bundle (.app/Contents/Resources/) — TCC их не блокирует.

LOG="$HOME/Library/Logs/ZubriTunnel.log"
mkdir -p "$(dirname "$LOG")"

HERE="$(cd "$(dirname "$0")" && pwd)"
RES="$(cd "$HERE/../Resources" && pwd)"

if [ ! -f "$RES/gui.py" ]; then
    osascript -e 'display alert "ZubriTunnel" message "Не нашёл gui.py внутри bundle. Скачай свежий релиз: github.com/AntonZubritski/ZubriTunnel/releases"'
    exit 1
fi

cd "$RES"

# 1. Сначала пробуем bundled Python внутри bundle (release-сборки).
#    arm64 на Apple Silicon, x86_64 на Intel.
ARCH="$(uname -m)"
case "$ARCH" in
    arm64)  BUNDLED="$HERE/../Frameworks/Python-arm64/bin/python3" ;;
    x86_64) BUNDLED="$HERE/../Frameworks/Python-x86_64/bin/python3" ;;
    *)      BUNDLED="" ;;
esac

if [ -n "$BUNDLED" ] && [ -x "$BUNDLED" ]; then
    if "$BUNDLED" -c "import tkinter" >/dev/null 2>&1; then
        PY="$BUNDLED"
    fi
fi

# Поиск рабочего Python — проверяем НЕ просто 'import tkinter', а реальное
# создание Tk()-окна. Apple-овский /usr/bin/python3 на минор-несовпадении
# macOS-сборки импорт проходит, но Tk() падает с 'macOS 15 (1507) required'.
find_working_python() {
    local candidates=(
        /opt/homebrew/bin/python3
        /opt/homebrew/bin/python3.12
        /opt/homebrew/bin/python3.11
        /opt/homebrew/bin/python3.10
        /usr/local/bin/python3
        /usr/local/bin/python3.12
        /usr/local/bin/python3.11
        /usr/local/bin/python3.10
        /Library/Frameworks/Python.framework/Versions/3.12/bin/python3
        /Library/Frameworks/Python.framework/Versions/3.11/bin/python3
        /Library/Frameworks/Python.framework/Versions/3.10/bin/python3
        "$(command -v python3 2>/dev/null)"
        /usr/bin/python3
    )
    local probe='import tkinter; r = tkinter.Tk(); r.withdraw(); r.destroy()'
    for p in "${candidates[@]}"; do
        [ -z "$p" ] && continue
        [ -x "$p" ] || continue
        if "$p" -c "$probe" >/dev/null 2>&1; then
            echo "$p"
            return 0
        fi
    done
    return 1
}

# 2. Если bundled нет (например git clone без релиза) — ищем системный
if [ -z "$PY" ]; then
    PY="$(find_working_python)"
fi

# 3. Если рабочий Python не найден ни там ни там — предлагаем авто-установку
if [ -z "$PY" ]; then
    INSTALL_SCRIPT="$RES/install_deps.sh"
    chmod +x "$INSTALL_SCRIPT" 2>/dev/null

    CHOICE=$(osascript <<EOF
set userChoice to button returned of (display dialog "Для работы ZubriTunnel нужен Python 3 + Tkinter.

Я могу установить их автоматически через Homebrew.
Откроется Terminal — там понадобится ввести пароль администратора (это нормально для Homebrew).

После завершения установки закрой Terminal и снова двойной клик по ZubriTunnel.app." buttons {"Отмена", "Установить"} default button "Установить" with icon caution with title "ZubriTunnel — нужен Python")
return userChoice
EOF
    )

    if [ "$CHOICE" = "Установить" ]; then
        # Открываем Terminal с инсталлером
        osascript <<EOF
tell application "Terminal"
    activate
    do script "bash \"$INSTALL_SCRIPT\""
end tell
EOF
    fi
    exit 0
fi

{
    echo ""
    echo "=== $(date) ==="
    echo "workdir: $RES"
    echo "python:  $PY ($($PY --version 2>&1))"

    # Tell Tcl/Tk where its runtime library lives. python-build-standalone
    # bakes /tools/deps/lib/tcl8.6 into the binary at build-time — that path
    # doesn't exist on the user's Mac, so Tk fails with 'init.tcl not found'.
    # Both libs ship inside the bundled Python's lib/ directory.
    PY_PREFIX="$(dirname "$(dirname "$PY")")"
    for v in 8.6 8.7 9.0; do
        if [ -d "$PY_PREFIX/lib/tcl${v}" ]; then
            export TCL_LIBRARY="$PY_PREFIX/lib/tcl${v}"
            break
        fi
    done
    for v in 8.6 8.7 9.0; do
        if [ -d "$PY_PREFIX/lib/tk${v}" ]; then
            export TK_LIBRARY="$PY_PREFIX/lib/tk${v}"
            break
        fi
    done
    echo "TCL_LIBRARY: ${TCL_LIBRARY:-<not set>}"
    echo "TK_LIBRARY:  ${TK_LIBRARY:-<not set>}"
    echo ""
    # exec -a "ZubriTunnel" rewrites argv[0] so 'ps', Activity Monitor and
    # macOS process name show 'ZubriTunnel' instead of 'python3'.
    exec -a "ZubriTunnel" "$PY" gui.py
} >> "$LOG" 2>&1

EXIT_CODE=$?
if [ "$EXIT_CODE" -ne 0 ]; then
    LAST="$(tail -25 "$LOG" | sed 's/"/\\"/g; s/$/\\n/g' | tr -d '\n' | head -c 1500)"
    osascript -e "display alert \"ZubriTunnel: ошибка запуска (код $EXIT_CODE)\" message \"Полный лог: ~/Library/Logs/ZubriTunnel.log\n\n$LAST\""
    exit "$EXIT_CODE"
fi

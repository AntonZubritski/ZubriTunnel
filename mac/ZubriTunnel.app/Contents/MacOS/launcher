#!/usr/bin/env bash
# Лаунчер ZubriTunnel.app
# Source-файлы внутри bundle (.app/Contents/Resources/) — TCC их не блокирует.

LOG="$HOME/Library/Logs/ZubriTunnel.log"
mkdir -p "$(dirname "$LOG")"

HERE="$(cd "$(dirname "$0")" && pwd)"
RES="$(cd "$HERE/../Resources" && pwd)"

if [ ! -f "$RES/gui.py" ]; then
    osascript -e 'display alert "ZubriTunnel" message "Не нашёл gui.py внутри bundle. Скачай свежий релиз: github.com/AntonZubritski/ZubriTunnel/releases"'
    exit 1
fi

cd "$RES"

# Поиск рабочего Python (с проверкой что tkinter импортируется)
find_working_python() {
    local candidates=(
        /opt/homebrew/bin/python3
        /opt/homebrew/bin/python3.12
        /opt/homebrew/bin/python3.11
        /opt/homebrew/bin/python3.10
        /usr/local/bin/python3
        /usr/local/bin/python3.12
        /usr/local/bin/python3.11
        /usr/local/bin/python3.10
        /Library/Frameworks/Python.framework/Versions/3.12/bin/python3
        /Library/Frameworks/Python.framework/Versions/3.11/bin/python3
        /Library/Frameworks/Python.framework/Versions/3.10/bin/python3
        "$(command -v python3 2>/dev/null)"
        /usr/bin/python3
    )
    for p in "${candidates[@]}"; do
        [ -z "$p" ] && continue
        [ -x "$p" ] || continue
        if "$p" -c "import tkinter" >/dev/null 2>&1; then
            echo "$p"
            return 0
        fi
    done
    return 1
}

PY="$(find_working_python)"

# Если рабочий Python не найден — предлагаем авто-установку
if [ -z "$PY" ]; then
    INSTALL_SCRIPT="$RES/install_deps.sh"
    chmod +x "$INSTALL_SCRIPT" 2>/dev/null

    CHOICE=$(osascript <<EOF
set userChoice to button returned of (display dialog "Для работы ZubriTunnel нужен Python 3 + Tkinter.

Я могу установить их автоматически через Homebrew.
Откроется Terminal — там понадобится ввести пароль администратора (это нормально для Homebrew).

После завершения установки закрой Terminal и снова двойной клик по ZubriTunnel.app." buttons {"Отмена", "Установить"} default button "Установить" with icon caution with title "ZubriTunnel — нужен Python")
return userChoice
EOF
    )

    if [ "$CHOICE" = "Установить" ]; then
        # Открываем Terminal с инсталлером
        osascript <<EOF
tell application "Terminal"
    activate
    do script "bash \"$INSTALL_SCRIPT\""
end tell
EOF
    fi
    exit 0
fi

{
    echo ""
    echo "=== $(date) ==="
    echo "workdir: $RES"
    echo "python:  $PY ($($PY --version 2>&1))"
    echo ""
    "$PY" gui.py
} >> "$LOG" 2>&1

EXIT_CODE=$?
if [ "$EXIT_CODE" -ne 0 ]; then
    LAST="$(tail -25 "$LOG" | sed 's/"/\\"/g; s/$/\\n/g' | tr -d '\n' | head -c 1500)"
    osascript -e "display alert \"ZubriTunnel: ошибка запуска (код $EXIT_CODE)\" message \"Полный лог: ~/Library/Logs/ZubriTunnel.log\n\n$LAST\""
    exit "$EXIT_CODE"
fi

#!/usr/bin/env bash
# Лаунчер ZubriTunnel.app
# Все source-файлы внутри bundle (.app/Contents/Resources/) — TCC sandbox их не блокирует.

LOG="$HOME/Library/Logs/ZubriTunnel.log"
mkdir -p "$(dirname "$LOG")"

HERE="$(cd "$(dirname "$0")" && pwd)"
RES="$(cd "$HERE/../Resources" && pwd)"

if [ ! -f "$RES/gui.py" ]; then
    osascript -e 'display alert "ZubriTunnel" message "Не нашёл gui.py внутри bundle. Скачай свежий релиз: github.com/AntonZubritski/ZubriTunnel/releases"'
    exit 1
fi

cd "$RES"

# Найти python3
PY="$(command -v python3 2>/dev/null)"
if [ -z "$PY" ]; then
    for p in /opt/homebrew/bin/python3 /usr/local/bin/python3 /usr/bin/python3; do
        if [ -x "$p" ]; then PY="$p"; break; fi
    done
fi
if [ -z "$PY" ]; then
    osascript -e 'display alert "ZubriTunnel" message "python3 не найден.\n\nУстанови: brew install python3\nили скачай: python.org/downloads/macos"'
    exit 1
fi

{
    echo ""
    echo "=== $(date) ==="
    echo "workdir: $RES"
    echo "python:  $PY ($($PY --version 2>&1))"
    echo ""
    "$PY" gui.py
} >> "$LOG" 2>&1

EXIT_CODE=$?
if [ "$EXIT_CODE" -ne 0 ]; then
    LAST="$(tail -25 "$LOG" | sed 's/"/\\"/g; s/$/\\n/g' | tr -d '\n' | head -c 1500)"
    osascript -e "display alert \"ZubriTunnel: ошибка запуска (код $EXIT_CODE)\" message \"Полный лог: ~/Library/Logs/ZubriTunnel.log\n\n$LAST\""
    exit "$EXIT_CODE"
fi

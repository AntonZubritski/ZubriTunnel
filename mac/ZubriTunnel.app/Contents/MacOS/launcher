#!/usr/bin/env bash
# Лаунчер ZubriTunnel.app
# Работает в двух режимах:
#   1. Self-contained (release): файлы внутри Contents/Resources/
#   2. Dev mode (git clone): файлы в родительской папке mac/

set -e
HERE="$(cd "$(dirname "$0")" && pwd)"

# Try Resources/ first (release build with bundled source)
RES="$(cd "$HERE/../Resources" 2>/dev/null && pwd || true)"
if [ -n "$RES" ] && [ -f "$RES/gui.py" ]; then
    WORKDIR="$RES"
elif [ -f "$HERE/../../../gui.py" ]; then
    # Dev mode: .app sits inside the mac/ folder next to gui.py
    WORKDIR="$(cd "$HERE/../../.." && pwd)"
else
    osascript -e 'display alert "ZubriTunnel" message "Не нашёл gui.py.\n\nЕсли ты перетащил .app, верни его в исходную папку или скачай свежий релиз: github.com/AntonZubritski/ZubriTunnel/releases"'
    exit 1
fi

cd "$WORKDIR"

if ! command -v python3 >/dev/null 2>&1; then
    osascript -e 'display alert "ZubriTunnel" message "python3 не найден.\n\nУстанови: brew install python3"'
    exit 1
fi

exec python3 gui.py

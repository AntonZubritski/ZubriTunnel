# Force LF line endings for files that must work on macOS / Linux
*.sh                                       text eol=lf
*.command                                  text eol=lf
*.py                                       text eol=lf
*.go                                       text eol=lf
*.yml                                      text eol=lf
mac/ZubriTunnel.app/Contents/MacOS/launcher text eol=lf
mac/ZubriTunnel.app/Contents/Info.plist     text eol=lf

# Binary files — never touch
*.png       binary
*.ico       binary
*.icns      binary
*.exe       binary
*.syso      binary

# Force CRLF for Windows-only scripts
*.bat       text eol=crlf
*.ps1       text eol=crlf
